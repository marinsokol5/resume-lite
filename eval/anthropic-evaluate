#!/usr/bin/env python3
"""
anthropic-evaluate

Measure how many *input tokens* one or more artifacts cost, using Anthropic's
token-counting endpoint (`POST /v1/messages/count_tokens`) — the ground-truth
count for a given model, free and unbilled. Built to compare session-handoff
artifacts (resume-lite `summary.md`, `--no-tools` variant, `/export` .txt, the
raw session `.jsonl`) so you can see the real token cost of each.

Works with both Claude Code and Codex sessions; the storage location a session
id resolves to selects the provider automatically.

Each positional arg is either a **file path** or a bare **session id**; mix them
freely. Per-arg handling:
    session id -> expands to the full comparison in one shot: the raw .jsonl
                  (the `--resume` baseline), resume-lite rendered in both
                  `--tools` and `--no-tools` modes (via the sibling
                  session-transcript script), and — if eval/exports/<id>.md
                  exists — the `/export` dump. Claude sessions are found in the
                  current project or anywhere under ~/.claude/projects; Codex
                  sessions under $CODEX_HOME/sessions (and archived_sessions).
    *.jsonl    -> reconstruct the conversation and count it as a full messages=[]
                  request (the honest proxy for what `--resume` re-ingests):
                  every user/assistant record, flattened to text, consecutive
                  same-role records merged so roles alternate. The provider
                  (Claude or Codex) is detected from the file's records.
    other file -> counted as a single user message containing the whole file
                  (summary.md, export .txt, a /compact summary, ...).

Usage:
    scripts/anthropic-evaluate <session-id | file> [...]
        [--model <id>]   # default claude-opus-4-8
        [--dry-run]      # don't call the API; print message/char counts only
        [--json]         # emit machine-readable JSON instead of a table

Auth (only needed without --dry-run): ANTHROPIC_API_KEY (sent as x-api-key), or
ANTHROPIC_AUTH_TOKEN (sent as a Bearer token for OAuth). No SDK required.

Note: the .jsonl count is an *upper bound* on the real --resume cost — it
includes every message (sidechains, tool I/O, thinking) rendered as text; the
live client drops some of that. Both .md/.txt and .jsonl are counted with no
system prompt or tools, so numbers reflect the artifact's content only.
"""

from __future__ import annotations

import argparse
import glob
import json
import os
import subprocess
import sys
import tempfile
import urllib.error
import urllib.request
from pathlib import Path

DEFAULT_MODEL = "claude-opus-4-8"
BASE_URL = os.environ.get("ANTHROPIC_BASE_URL", "https://api.anthropic.com").rstrip("/")
ENDPOINT = "/v1/messages/count_tokens"
API_VERSION = "2023-06-01"
PROJECTS_DIR = Path.home() / ".claude" / "projects"
CODEX_HOME = Path(os.environ.get("CODEX_HOME") or Path.home() / ".codex")
CODEX_SESSION_DIRS = (CODEX_HOME / "sessions", CODEX_HOME / "archived_sessions")
# Bundled skill parser that renders a session .jsonl into a light transcript.
TRANSCRIPT = Path(__file__).resolve().parent.parent / "skills" / "resume-lite" / "scripts" / "session-transcript"
# Where `/export <id>.md` dumps live; a session id auto-picks up eval/exports/<id>.md.
EXPORTS_DIR = Path(__file__).resolve().parent / "exports"


# ---- resolve an arg into the artifacts to size --------------------------

def _project_dir() -> Path:
    """The current directory's Claude Code project storage dir (id-encoded cwd)."""
    encoded = "".join(c if c.isalnum() else "-" for c in os.getcwd())
    return PROJECTS_DIR / encoded


def _codex_session_files():
    """Yield active and archived Codex JSONL files without duplicating symlinks."""
    seen = set()
    for root in CODEX_SESSION_DIRS:
        if not root.is_dir():
            continue
        for path in root.rglob("*.jsonl"):
            key = str(path.resolve())
            if key not in seen:
                seen.add(key)
                yield path


def _detect_provider(path: Path) -> str:
    """Provider of a session file from its first recognizable record; 'claude' if unsure."""
    try:
        for i, line in enumerate(path.open(encoding="utf-8")):
            if i >= 50:
                break
            try:
                rec = json.loads(line)
            except json.JSONDecodeError:
                continue
            typ = rec.get("type")
            if typ == "session_meta" and isinstance(rec.get("payload"), dict):
                return "codex"
            if typ in ("user", "assistant") and isinstance(rec.get("message"), dict):
                return "claude"
            if typ in ("response_item", "event_msg", "turn_context"):
                return "codex"
    except OSError:
        pass
    return "claude"


def _codex_canonical_id(path: Path) -> str:
    """Codex session's stable id from its session_meta record; stem as fallback."""
    try:
        for i, line in enumerate(path.open(encoding="utf-8")):
            if i >= 50:
                break
            try:
                rec = json.loads(line)
            except json.JSONDecodeError:
                continue
            payload = rec.get("payload")
            if rec.get("type") == "session_meta" and isinstance(payload, dict) \
                    and isinstance(payload.get("id"), str):
                return payload["id"]
    except OSError:
        pass
    return path.stem


def find_session(arg: str) -> tuple[Path, str] | None:
    """Locate a session id and its provider: this Claude project first, then any
    Claude project, then Codex stores. Codex ids match the rollout's `-<id>` tail.
    Returns (path, provider) or None if nothing matches."""
    sid = arg[:-6] if arg.endswith(".jsonl") else arg
    current = _project_dir() / f"{sid}.jsonl"
    if current.is_file():
        return current, "claude"
    for hit in glob.glob(str(PROJECTS_DIR / "**" / f"{sid}.jsonl"), recursive=True):
        return Path(hit), "claude"
    for path in _codex_session_files():
        stem = path.stem
        if stem == sid or stem.endswith(f"-{sid}"):
            return path, "codex"
    return None


def canonical_sid(path: Path, provider: str) -> str:
    """The id used for labels, the exports lookup, and the transcript subprocess."""
    return _codex_canonical_id(path) if provider == "codex" else path.stem


def render_transcript(sid: str, mode: str) -> Path | None:
    """Run the sibling session-transcript for `mode` (--tools/--no-tools). Path or None."""
    out = Path(tempfile.gettempdir()) / "anthropic-evaluate" / f"{sid}{mode}.md"
    out.parent.mkdir(parents=True, exist_ok=True)
    r = subprocess.run([sys.executable, str(TRANSCRIPT), sid, mode, "--out", str(out)],
                       capture_output=True, text=True)
    return out if r.returncode == 0 and out.is_file() else None


def items_for_arg(arg: str) -> list[tuple[str, str | None, list[dict] | None]]:
    """(label, kind, messages) rows for one arg. A session id expands to three rows:
    raw .jsonl (the --resume baseline) + resume-lite in +tools and --no-tools modes."""
    p = Path(arg)
    if p.is_file():  # explicit file path stays literal (one row)
        kind = "jsonl" if p.suffix == ".jsonl" else "single"
        return [(p.name, kind, build_messages(p))]

    found = find_session(arg)
    if found is None:
        return [(arg, None, None)]  # unresolvable -> error row
    path, provider = found
    sid = canonical_sid(path, provider)
    short = sid[:8]
    rows: list[tuple[str, str | None, list[dict] | None]] = [
        (f"{short} --resume (.jsonl)", "jsonl", jsonl_messages(path, provider)),
    ]
    export = EXPORTS_DIR / f"{sid}.md"  # a matching /export dump, if one exists
    if export.is_file():
        rows.append((f"{short} /export", "single", build_messages(export)))
    for mode in ("--tools", "--no-tools"):
        md = render_transcript(sid, mode)
        label = f"{short} light {mode}"
        rows.append((label, "single", build_messages(md)) if md
                    else (label, None, None))
    return rows


# ---- .jsonl -> messages reconstruction ----------------------------------

def _block_text(block: dict) -> str:
    """Flatten one content block to the text that carries its token weight."""
    t = block.get("type")
    if t == "text":
        return block.get("text", "")
    if t == "thinking":
        return block.get("thinking", "")
    if t == "tool_use":
        name = block.get("name", "tool")
        return f"[tool_use {name} {json.dumps(block.get('input', {}), ensure_ascii=False)}]"
    if t == "tool_result":
        c = block.get("content")
        if isinstance(c, str):
            body = c
        elif isinstance(c, list):
            body = "\n".join(b.get("text", "") for b in c
                             if isinstance(b, dict) and b.get("type") == "text")
        else:
            body = ""
        return f"[tool_result{' error' if block.get('is_error') else ''}] {body}"
    if t == "image":
        return "[image]"
    return ""  # unknown block types contribute ~nothing as text


def _flatten(content) -> str:
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        return "\n".join(s for s in (_block_text(b) for b in content
                                     if isinstance(b, dict)) if s)
    return ""


def _append(msgs: list[dict], role: str, text: str) -> None:
    """Add a turn, merging into the previous one when the role repeats."""
    text = text.strip()
    if not text:
        return
    if msgs and msgs[-1]["role"] == role:
        msgs[-1]["content"] += "\n" + text
    else:
        msgs.append({"role": role, "content": text})


def _finish(msgs: list[dict]) -> list[dict]:
    while msgs and msgs[0]["role"] != "user":  # API requires the first turn to be user
        msgs.pop(0)
    return msgs


def _claude_jsonl_messages(path: Path) -> list[dict]:
    """All Claude user/assistant turns as text messages, consecutive same-role merged."""
    msgs: list[dict] = []
    for line in path.open(encoding="utf-8"):
        line = line.strip()
        if not line:
            continue
        try:
            rec = json.loads(line)
        except json.JSONDecodeError:
            continue
        if rec.get("type") not in ("user", "assistant"):
            continue
        msg = rec.get("message")
        if not isinstance(msg, dict):
            continue
        role = msg.get("role")
        if role not in ("user", "assistant"):
            continue
        _append(msgs, role, _flatten(msg.get("content")))
    return _finish(msgs)


def _codex_content_text(content) -> str:
    """Join the text blocks of a Codex `message` content array."""
    if not isinstance(content, list):
        return ""
    parts = [b.get("text", "") for b in content if isinstance(b, dict)
             and b.get("type") in ("input_text", "output_text", "text")
             and isinstance(b.get("text"), str)]
    return "\n".join(p for p in parts if p)


def _codex_reasoning_text(payload: dict) -> str:
    """Visible reasoning (summary + any plaintext content); the encrypted blob is skipped."""
    parts: list[str] = []
    for key in ("summary", "content"):
        blocks = payload.get(key)
        if isinstance(blocks, list):
            parts += [b.get("text", "") for b in blocks
                      if isinstance(b, dict) and isinstance(b.get("text"), str)]
    return "\n".join(p for p in parts if p)


def _codex_response_item(payload: dict) -> tuple[str, str] | None:
    """Flatten a Codex response_item into (role, text). None for non-conversation items."""
    t = payload.get("type")
    if t == "message":
        role = payload.get("role")
        if role in ("user", "assistant"):
            return role, _codex_content_text(payload.get("content"))
        return None
    if t == "reasoning":
        return "assistant", _codex_reasoning_text(payload)
    if t == "function_call":
        name = payload.get("name", "tool")
        args = payload.get("arguments")
        args = args if isinstance(args, str) else json.dumps(args or {}, ensure_ascii=False)
        return "assistant", f"[tool_use {name} {args}]"
    if t == "custom_tool_call":
        name = payload.get("name", "tool")
        inp = payload.get("input")
        inp = inp if isinstance(inp, str) else json.dumps(inp or {}, ensure_ascii=False)
        return "assistant", f"[tool_use {name} {inp}]"
    if t in ("function_call_output", "custom_tool_call_output"):
        out = payload.get("output")
        out = out if isinstance(out, str) else json.dumps(out or "", ensure_ascii=False)
        return "user", f"[tool_result] {out}"
    return None  # ghost_snapshot, plan updates, etc. carry no token weight here


def _codex_jsonl_messages(path: Path) -> list[dict]:
    """Codex conversation as text messages. Reconstructed from `response_item` records
    (the actual model-input history); `event_msg` records are UI duplicates and skipped.
    Tool calls map to assistant turns, tool outputs to user turns, so roles alternate."""
    msgs: list[dict] = []
    for line in path.open(encoding="utf-8"):
        line = line.strip()
        if not line:
            continue
        try:
            rec = json.loads(line)
        except json.JSONDecodeError:
            continue
        if rec.get("type") != "response_item":
            continue
        payload = rec.get("payload")
        if not isinstance(payload, dict):
            continue
        parsed = _codex_response_item(payload)
        if parsed:
            _append(msgs, *parsed)
    return _finish(msgs)


def jsonl_messages(path: Path, provider: str | None = None) -> list[dict]:
    """Reconstruct a session .jsonl into alternating text messages (provider auto-detected)."""
    if provider is None:
        provider = _detect_provider(path)
    if provider == "codex":
        return _codex_jsonl_messages(path)
    return _claude_jsonl_messages(path)


def build_messages(path: Path) -> list[dict]:
    if path.suffix == ".jsonl":
        return jsonl_messages(path)
    return [{"role": "user", "content": path.read_text(encoding="utf-8")}]


# ---- token counting -----------------------------------------------------

def auth_headers() -> dict[str, str]:
    key = os.environ.get("ANTHROPIC_API_KEY")
    if key:
        return {"x-api-key": key}
    token = os.environ.get("ANTHROPIC_AUTH_TOKEN")
    if token:
        return {"Authorization": f"Bearer {token}", "anthropic-beta": "oauth-2025-04-20"}
    sys.exit("no credentials: set ANTHROPIC_API_KEY (or ANTHROPIC_AUTH_TOKEN), "
             "or pass --dry-run to skip the API")


def count_tokens(messages: list[dict], model: str, headers: dict[str, str]) -> int:
    body = json.dumps({"model": model, "messages": messages}).encode("utf-8")
    req = urllib.request.Request(
        BASE_URL + ENDPOINT, data=body, method="POST",
        headers={"content-type": "application/json",
                 "anthropic-version": API_VERSION, **headers},
    )
    try:
        with urllib.request.urlopen(req) as resp:
            return json.loads(resp.read())["input_tokens"]
    except urllib.error.HTTPError as e:
        detail = e.read().decode("utf-8", "replace")[:400]
        raise SystemExit(f"count_tokens HTTP {e.code}: {detail}")


# ---- CLI ----------------------------------------------------------------

def main() -> None:
    ap = argparse.ArgumentParser(add_help=True)
    ap.add_argument("files", nargs="+", metavar="ARG",
                    help="session id or file path (mix freely)")
    ap.add_argument("--model", default=DEFAULT_MODEL, help=f"default {DEFAULT_MODEL}")
    ap.add_argument("--dry-run", action="store_true",
                    help="skip the API; show message/char counts only")
    ap.add_argument("--json", action="store_true", help="emit JSON")
    args = ap.parse_args()

    headers = None if args.dry_run else auth_headers()
    rows = []
    for f in args.files:
        for label, kind, msgs in items_for_arg(f):
            if kind is None:
                rows.append({"file": label, "error": "no such file or session id"})
                continue
            chars = sum(len(m["content"]) for m in msgs)
            row = {"file": label, "kind": kind, "messages": len(msgs), "chars": chars}
            if not msgs:
                row["error"] = "no messages"
            elif not args.dry_run:
                row["tokens"] = count_tokens(msgs, args.model, headers)
            rows.append(row)

    toks = [r["tokens"] for r in rows if "tokens" in r]
    lo = min(toks) if toks else 0
    if args.json:
        print(json.dumps(rows, indent=2))
        return

    # Table
    w = max((len(r["file"]) for r in rows), default=4)
    if args.dry_run:
        print(f"{'SOURCE':<{w}}  {'KIND':<6} {'MSGS':>5} {'CHARS':>9} {'~TOK':>8}")
        for r in rows:
            if "error" in r:
                print(f"{r['file']:<{w}}  {r['error']}")
                continue
            print(f"{r['file']:<{w}}  {r['kind']:<6} {r['messages']:>5} "
                  f"{r['chars']:>9,} {r['chars']//4:>8,}")
        print("\n(--dry-run: ~TOK is chars/4, a rough estimate; drop --dry-run for exact counts)")
        return

    print(f"{'SOURCE':<{w}}  {'KIND':<6} {'MSGS':>5} {'TOKENS':>9} {'×MIN':>6}")
    for r in rows:
        if "error" in r:
            print(f"{r['file']:<{w}}  {r['error']}")
            continue
        ratio = f"{r['tokens']/lo:.2f}×" if lo else "-"
        print(f"{r['file']:<{w}}  {r['kind']:<6} {r['messages']:>5} "
              f"{r['tokens']:>9,} {ratio:>6}")
    print(f"\nmodel: {args.model}  ·  counted via {ENDPOINT} (unbilled)")


if __name__ == "__main__":
    main()
